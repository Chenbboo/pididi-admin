{
  "bsonType": "object",
  "required": ["title", "category", "content"],
  "permission": {
    "read": true,
    "create": "auth.uid != null",
    "update": "auth.uid != null",
    "delete": "auth.uid != null"
  },
  "properties": {
    "_id": { "bsonType": "string" },
    "title": { "bsonType": "string", "title": "标题", "trim": "both" },
    "category": {
      "bsonType": "string",
      "title": "分类",
      "enum": [
        { "value": "目的地攻略", "text": "目的地攻略" },
        { "value": "主题玩法", "text": "主题玩法" },
        { "value": "行程规划", "text": "行程规划" },
        { "value": "出行攻略", "text": "出行攻略" },
        { "value": "避坑指南", "text": "避坑指南" },
        { "value": "本地文化", "text": "本地文化" }
      ]
    },
    "destination_id": { "bsonType": "string", "title": "关联目的地" },
    "cover": { "bsonType": "string", "title": "封面图", "trim": "both" },
    "cover_image": { "bsonType": "string", "title": "封面图(旧)", "trim": "both" },
    "summary": { "bsonType": "string", "title": "摘要", "maxLength": 200 },
    "content": { "bsonType": "string", "title": "正文（富文本HTML）" },
    "tags": { "bsonType": "array", "title": "标签", "items": { "bsonType": "string" } },
    "views": { "bsonType": "int", "title": "浏览量", "defaultValue": 0 },
    "view_count": { "bsonType": "int", "title": "浏览量(旧)", "defaultValue": 0 },
    "collects": { "bsonType": "int", "title": "收藏数", "defaultValue": 0 },
    "collect_count": { "bsonType": "int", "title": "收藏数(旧)", "defaultValue": 0 },
    "publish_date": { "bsonType": "timestamp", "title": "发布时间" },
    "status": {
      "bsonType": "string",
      "title": "状态",
      "enum": ["draft", "published"],
      "defaultValue": "draft"
    },
    "create_time": { "bsonType": "timestamp", "title": "创建时间" },
    "update_time": { "bsonType": "timestamp", "title": "更新时间" }
  }
}
